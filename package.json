{
  "name": "@xs-and-10s/alphabetica",
  "version": "0.5.0",
  "description": "26 letters plus _, one per utility. A tiny, dependency-free combinator library for testing, DevOps scripting, code golf, and sandboxed execution.",
  "keywords": [
    "testing",
    "bdd",
    "minikanren",
    "logic-programming",
    "trampoline",
    "pattern-matching",
    "combinators",
    "utility",
    "shell",
    "dsl"
  ],
  "homepage": "https://github.com/Xs-and-10s/alphabetica#readme",
  "bugs": {
    "url": "https://github.com/Xs-and-10s/alphabetica/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xs-and-10s/alphabetica.git"
  },
  "license": "MIT",
  "author": "Mark (@Xs-and-10s)",
  "type": "module",
  "main": "./alphabetica.mjs",
  "types": "./dist/alphabetica.d.ts",
  "exports": {
    ".": {
      "types": "./dist/alphabetica.d.ts",
      "import": "./alphabetica.mjs",
      "require": "./dist/cjs/alphabetica.js",
      "default": "./alphabetica.mjs"
    },
    "./ts": "./alphabetica.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "alphabetica.ts",
    "alphabetica.mjs",
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:types && npm run build:cjs",
    "build:types": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/write-cjs-marker.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx alphabetica.test.ts && tsx exhaustive.test.ts && node alphabetica.test.mjs && npm run test:cjs && npm run test:types && npm run test:fuzz",
    "test:ts": "tsx alphabetica.test.ts",
    "test:exhaustive": "tsx exhaustive.test.ts",
    "test:mjs": "node alphabetica.test.mjs",
    "test:cjs": "npm run build:cjs && node alphabetica.test.cjs",
    "test:cjs:run": "node alphabetica.test.cjs",
    "test:types": "tsc --noEmit alphabetica.test-d.ts --target esnext --module esnext --moduleResolution bundler --strict --allowImportingTsExtensions --skipLibCheck --types node",
    "test:fuzz": "node alphabetica.fuzz.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "expect-type": "^1.3.0",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
